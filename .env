# Local secrets — do not commit (see .gitignore). Copy from .env.example.

# FlightAware AeroAPI (flight MCP — x-apikey)
FLIGHTAWARE_API_KEY=

# BigQuery (bigquery MCP) — Application Default Credentials or GOOGLE_APPLICATION_CREDENTIALS
BIGQUERY_PROJECT=
# Optional overrides (defaults: aero_reference / airports)
BIGQUERY_DATASET=aero_reference
BIGQUERY_TRAVEL_TABLE=airports

# Demo agent (main.py)
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_BASE_URL=http://localhost:11434
AGENT_MAX_STEPS=24
AGENT_QUERY="At Houston Bush (KIAH), use our airport reference for the official name and city. Then summarize live activity: 
flight counts (departed, enroute, scheduled arrivals and departures), plus whether recent arrivals or departures look unusually delayed."
SECOND_AGENT_QUERY="Compare Houston Hobby (KSFO) and Bush (KIAH): official names and cities from our catalog, then contrast 
live flight counts and recent arrival and departure activity — which airport looks busier or more disrupted?"

# Trace (main.py): MCP + LangChain debug, StdOutCallbackHandler, stderr context dumps
FLIGHT_BOOKING_AGENT_TRACE=1